  "bugs": {
    "url": "https://github.com/your-username/tutorly/issues"
  },
  "homepage": "https://github.com/your-username/tutorly#readme",
  "engines": {
    "python": ">=3.7"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
