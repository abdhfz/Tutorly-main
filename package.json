{
  "name": "tutorly-frontend",
  "version": "1.0.0",
  "description": "AI-Powered Educational Platform Frontend",
  "type": "module",
  "scripts": {
    "start": "python run_server.py",
    "server": "python app.py",
    "dev": "vite",
    "dev:api": "python run_server.py",
    "build": "vite build",
    "preview": "vite preview",
    "serve": "python run_server.py",
    "install-deps": "pip install -r requirements.txt",
    "setup": "npm install && pip install -r requirements.txt && npm run build && python run_server.py",
    "health": "curl http://localhost:5000/api/health",
    "test-api": "curl -X GET http://localhost:5000/api/health && echo '\nAPI is working!'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/tutorly.git"
  },
  "keywords": [
    "education",
    "ai",
    "tutoring",
    "gemini",
    "flask",
    "react",
    "learning"
  ],
  "author": "Your Name",
